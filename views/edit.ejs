<%- include("partials/header.ejs") %>

<main class="flex-fill">
    <form action="/edit/<%= post.slug %>" method="post" class="mx-4 mx-md-auto p-4 mt-5 border rounded-4 bg-transparent border-white border-2 shadow-lg content-box edit-box" style="max-width: 700px;">
        <div class="mx-3">
            <div class="mt-3 mb-4">
                <input type="text" name="topic" value="<%= post.topic %>" class="form-control border rounded-4 bg-transparent text-white border-2" id="floatingInput" required>
            </div>
            <div class="mb-5">
                <textarea name="content" class="form-control border rounded-4 bg-transparent text-white border-2" id="exampleFormControlTextarea1" rows="3" style="height: 300px" required><%= post.content %></textarea>
            </div>
            
            <div class="mt-auto gap-3 d-flex flex-wrap justify-content-center">
                <button type="submit" class="btn rounded-4 px-3 gap-4 edit-button">Confirm</button> 
                <button type="submit" class="btn btn-outline-light rounded-4 px-3 delete-button" onclick="window.location.href='/view/<%= post.slug %>'">
                    Cancel
                </button> 
            </div>
        </div>
    </form>
</main>

<%- include("partials/footer.ejs") %>