<%- include("partials/header.ejs") %>

<main class="flex-fill">

    <!-- Bootstrap -->
    <div class="mx-4 my-4">
        <a href="/" class="btn btn-outline-light btn-sm rounded-4">&larr; Back to Home</a>
    </div>

    <!-- Content -->
    <div class="content-box d-flex flex-column mx-4 mx-md-auto px-4 py-4 my-4 mt-5 text-center view border rounded-4 border-white border-2 shadow-lg"> 
        <h1 class="display-5 my-4"><%= post.topic %></h1> 
        <div class="mx-auto py-3 px-3 view-text"> 
            <p class="mb-4"><%= post.content %></p>
        </div> 

        <div class="mt-auto gap-3 d-flex flex-wrap justify-content-center"> 
            <form action="/edit/<%= post.slug %>" method="get">
                <button type="submit" class="btn rounded-4 px-3 gap-4 edit-button">Edit</button> 
            </form>
            <form id="deleteForm" action="/delete/<%= post.slug %>" method="post">
                <button type="submit" class="btn btn-outline-light rounded-4 px-3 delete-button">Delete</button> 
            </form>
        </div>
    </div>
</main>

<%- include("partials/footer.ejs") %>

